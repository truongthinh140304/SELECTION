{
    "manifest_version": 3,
    "name": "Selection Translate & Wiki",
    "version": "1.0",
    "description": "Dịch và tra Wikipedia khi bôi đen text trên trang web",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://vi.wikipedia.org/*",
        "https://en.wikipedia.org/*",
        "https://api.mymemory.translated.net/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content.js"
            ],
            "css": [
                "src/content.css"
            ],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "src/background.js"
    },
    "action": {
        "default_title": "Selection Translate & Wiki"
    },
    "icons": {
        "16": "assets/icon-16.svg",
        "48": "assets/icon-48.svg",
        "128": "assets/icon-128.svg"
    }
}