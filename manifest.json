{
    "manifest_version": 3,
    "name": "Selection Translate & Wiki",
    "version": "1.2",
    "description": "Dịch và tra Wikipedia khi bôi đen text trên trang web",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://vi.wikipedia.org/*",
        "https://en.wikipedia.org/*",
        "https://api.mymemory.translated.net/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "src/content/highlight-dom.js",
                "dist/content-react.js"
            ],
            "css": [
                "dist/content-react.css"
            ],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "src/background/background.js"
    },
    "action": {
        "default_title": "Selection Translate & Wiki"
    },
    "icons": {
        "16": "assets/icon-16.png",
        "32": "assets/icon-32.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    }
}